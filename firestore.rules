rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 1. Primitive Definitions
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isAdmin() { 
      return isSignedIn() && request.auth.token.email == 'jmisagor079@gmail.com' && request.auth.token.email_verified == true; 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // 2. Validation Helpers
    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.description is string && data.description.size() <= 1000 &&
             data.price is number && data.price >= 0 &&
             data.imageUrl is string && data.imageUrl.size() <= 2000 &&
             data.category is string && data.category.size() <= 100 &&
             data.stock is number && data.stock >= 0;
    }

    function isValidOrder(data) {
      return data.userId is string && data.userId.size() <= 128 &&
             data.customerName is string && data.customerName.size() <= 200 &&
             data.customerEmail is string && data.customerEmail.size() <= 200 &&
             data.totalAmount is number && data.totalAmount >= 0 &&
             data.status in ['pending', 'processing', 'shipped', 'delivered', 'cancelled'] &&
             data.items is list && data.items.size() > 0 && data.items.size() <= 50;
    }

    // 3. Collection Rules
    
    // Products Collection
    match /products/{productId} {
      allow read: if true; 
      
      allow create: if isAdmin() && 
                      isValidProduct(incoming()) && 
                      incoming().keys().hasAll(['name', 'price', 'imageUrl', 'stock', 'createdAt']) &&
                      incoming().keys().size() >= 5;

      allow update: if isAdmin() && 
                      isValidProduct(incoming()) &&
                      (
                        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description', 'price', 'imageUrl', 'category', 'stock'])
                      );

      allow delete: if isAdmin();
    }

    // Orders Collection
    match /orders/{orderId} {
      allow list, get: if isAdmin(); 
      
      allow create: if (
        isValidOrder(incoming()) &&
        incoming().status == 'pending' &&
        incoming().createdAt == request.time
      );

      allow update: if isAdmin() &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
                      incoming().status in ['pending', 'processing', 'shipped', 'delivered', 'cancelled'];

      allow delete: if isAdmin();
    }
  }
}
